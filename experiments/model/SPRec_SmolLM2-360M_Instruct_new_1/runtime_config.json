{
  "base_model": "HuggingFaceTB/SmolLM2-360M-Instruct",
  "resume_from_checkpoint": "./experiments/model/sft_model_SmolLM2-360M_Instruct/final_model",
  "output_dir": "./experiments/model/SPRec_SmolLM2-360M_Instruct_new",
  "config_path": "./configs/dpo_config.yaml",
  "train_data_path": "./experiments/data/selfplay_SmolLM2-360M_Instruct/train_new.json",
  "valid_data_path": "./experiments/data/selfplay_SmolLM2-360M_Instruct/valid_new.json",
  "dpo": {
    "beta": 0.1,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 16,
    "warmup_steps": 20,
    "num_train_epochs": 2,
    "learning_rate": 2e-05,
    "bf16": true,
    "logging_steps": 1,
    "optim": "adamw_torch",
    "evaluation_strategy": "steps",
    "save_strategy": "steps",
    "save_total_limit": 3,
    "load_best_model_at_end": true,
    "max_prompt_length": 512,
    "max_length": 512
  }
}