{
  "base_model": "meta-llama/Llama-3.2-1B-Instruct",
  "resume_from_checkpoint": "./experiments/model/sft_model_Llama-3.2-1B-Instruct_new/final_model",
  "output_dir": "./experiments/model/clusterout_low_Llama-3.2-1B-Instruct_on_new_sft_model",
  "config_path": "./configs/ClusterExposure_DPO/dpo_config.yaml",
  "train_data_path": "./test/clusterout_low_on_new_sft_model/train.json",
  "valid_data_path": "./test/clusterout_low_on_new_sft_model/valid.json",
  "dpo": {
    "beta": 0.1,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 16,
    "warmup_steps": 20,
    "num_train_epochs": 2,
    "learning_rate": 2e-05,
    "bf16": true,
    "logging_steps": 1,
    "optim": "adamw_torch",
    "evaluation_strategy": "steps",
    "save_strategy": "steps",
    "load_best_model_at_end": true,
    "max_prompt_length": 512,
    "max_length": 512
  }
}